    "expo-network": "~55.0.13",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.13",
    "expo-sensors": "^55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-splash-screen": "~55.0.10",
    "expo-system-ui": "~55.0.9",
    "expo-task-manager": "~55.0.15",
    "expo-updates": "~55.0.21",
    "expo-widgets": "^55.0.12",
    "i18next": "^23.14.0",
    "intl-pluralrules": "^2.0.1",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.0.1",
    "react-native": "0.83.4",
    "react-native-background-actions": "^4.1.0",
    "react-native-ble-plx": "^3.5.1",
    "react-native-calendars": "^1.1314.0",
    "react-native-drawer-layout": "^4.0.1",
    "react-native-edge-to-edge": "~1.6.1",
    "react-native-gesture-handler": "~2.30.0",
