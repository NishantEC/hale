# Observability (Sentry). Unset → Sentry is a no-op; set in production
# to send native + JS crashes and breadcrumbs. Requires
# `pnpm add @sentry/react-native` once you're ready to wire it in.
# EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/YYYY
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
# EXPO_PUBLIC_SENTRY_RELEASE=
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
