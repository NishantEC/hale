PORT=3009
BETTER_AUTH_URL=http://localhost:3009
DEBUG_INSPECTOR_ENABLED=true
DB_HOST=localhost
DB_PORT=5434
DB_USER=noop
DB_PASSWORD=noop_dev
DB_NAME=noop
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Postgres pool sizing. Defaults (max=5) are fine for single-user dev.
# Production behind Cloud Run: set DB_POOL_MAX to match the chosen max
# instance count × per-instance pool size = total < Cloud SQL max_connections.
# DB_POOL_MAX=5
# AUTH_DB_POOL_MAX=2
# DB_POOL_IDLE_TIMEOUT_MS=10000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Observability (Sentry). Unset → Sentry is a no-op; set in production
# to send unhandled exceptions and traces.
# SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/YYYY
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
