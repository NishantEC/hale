{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "moduleResolution": "node",
    "module": "esnext",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "resolveJsonModule": true
  },
  "exclude": ["node_modules"]
}
